<?xml version="1.0" ?>
<robot name="adeept_5dof">

  <material name="darkblue"><color rgba="0.15 0.15 0.35 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="orange"><color rgba="0.95 0.6 0.1 1.0"/></material>
  <material name="green"><color rgba="0.1 0.75 0.5 1.0"/></material>
  <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>

  <!-- BASE -->
  <link name="base_link">
    <visual><geometry><box size="0.100 0.100 0.015"/></geometry>
      <origin xyz="0 0 0.0075"/><material name="darkblue"/></visual>
    <visual><geometry><cylinder radius="0.037" length="0.003"/></geometry>
      <origin xyz="0 0 0.0165"/><material name="grey"/></visual>
    <collision><geometry><box size="0.100 0.100 0.018"/></geometry><origin xyz="0 0 0.009"/></collision>
    <inertial><mass value="0.3"/><origin xyz="0 0 0.009"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <!-- TURNTABLE -->
  <link name="turntable">
    <visual><geometry><cylinder radius="0.031" length="0.008"/></geometry>
      <origin xyz="0 0 0.004"/><material name="grey"/></visual>
    <collision><geometry><cylinder radius="0.032" length="0.008"/></geometry><origin xyz="0 0 0.004"/></collision>
    <inertial><mass value="0.05"/><origin xyz="0 0 0.004"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="base_joint" type="revolute">
    <parent link="base_link"/><child link="turntable"/>
    <origin xyz="0 0 0.018"/><axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <!-- SHOULDER BRACKET -->
  <link name="shoulder_bracket">
    <visual><geometry><box size="0.003 0.035 0.060"/></geometry>
      <origin xyz="-0.020 0 0.030"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.003 0.035 0.060"/></geometry>
      <origin xyz="0.020 0 0.030"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.043 0.003 0.036"/></geometry>
      <origin xyz="0 -0.0175 0.018"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.023 0.040 0.012"/></geometry>
      <origin xyz="0 0 0.060"/><material name="white"/></visual>
    <visual><geometry><cylinder radius="0.0025" length="0.045"/></geometry>
      <origin xyz="0 0 0.060" rpy="0 1.5708 0"/><material name="orange"/></visual>
    <collision><geometry><box size="0.045 0.040 0.072"/></geometry><origin xyz="0 0 0.036"/></collision>
    <inertial><mass value="0.12"/><origin xyz="0 0 0.036"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/></inertial>
  </link>

  <joint name="shoulder_bracket_joint" type="fixed">
    <parent link="turntable"/><child link="shoulder_bracket"/>
    <origin xyz="0 0 0.008"/>
  </joint>

  <!-- UPPER ARM -->
  <link name="upper_arm">
    <visual><geometry><box size="0.003 0.035 0.105"/></geometry>
      <origin xyz="-0.0175 0 0.0525"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.003 0.035 0.105"/></geometry>
      <origin xyz="0.0175 0 0.0525"/><material name="darkblue"/></visual>
    <visual><geometry><cylinder radius="0.0015" length="0.032"/></geometry>
      <origin xyz="0 0.01225 0.016" rpy="0 1.5708 0"/><material name="grey"/></visual>
    <visual><geometry><cylinder radius="0.0015" length="0.032"/></geometry>
      <origin xyz="0 -0.01225 0.016" rpy="0 1.5708 0"/><material name="grey"/></visual>
    <visual><geometry><box size="0.023 0.040 0.012"/></geometry>
      <origin xyz="0 0 0.105"/><material name="white"/></visual>
    <visual><geometry><cylinder radius="0.0025" length="0.040"/></geometry>
      <origin xyz="0 0 0.105" rpy="0 1.5708 0"/><material name="orange"/></visual>
    <collision><geometry><box size="0.038 0.040 0.118"/></geometry><origin xyz="0 0 0.059"/></collision>
    <inertial><mass value="0.12"/><origin xyz="0 0 0.059"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="shoulder_bracket"/><child link="upper_arm"/>
    <origin xyz="0 0 0.060"/><axis xyz="1 0 0"/>
    <limit lower="-0.0873" upper="1.3963" effort="10" velocity="1.0"/>
  </joint>

  <!-- FOREARM -->
  <link name="forearm">
    <visual><geometry><box size="0.003 0.030 0.095"/></geometry>
      <origin xyz="-0.015 0 0.0475"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.003 0.030 0.095"/></geometry>
      <origin xyz="0.015 0 0.0475"/><material name="darkblue"/></visual>
    <visual><geometry><cylinder radius="0.0015" length="0.027"/></geometry>
      <origin xyz="0 0.0105 0.014" rpy="0 1.5708 0"/><material name="grey"/></visual>
    <visual><geometry><cylinder radius="0.0015" length="0.027"/></geometry>
      <origin xyz="0 -0.0105 0.014" rpy="0 1.5708 0"/><material name="grey"/></visual>
    <visual><geometry><box size="0.023 0.040 0.012"/></geometry>
      <origin xyz="0 0 0.095"/><material name="white"/></visual>
    <visual><geometry><cylinder radius="0.002" length="0.035"/></geometry>
      <origin xyz="0 0 0.095" rpy="0 1.5708 0"/><material name="orange"/></visual>
    <collision><geometry><box size="0.033 0.035 0.108"/></geometry><origin xyz="0 0 0.054"/></collision>
    <inertial><mass value="0.10"/><origin xyz="0 0 0.054"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.00008"/></inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm"/><child link="forearm"/>
    <origin xyz="0 0 0.105"/><axis xyz="1 0 0"/>
    <limit lower="-0.0873" upper="1.4835" effort="10" velocity="1.0"/>
  </joint>

  <!-- WRIST -->
  <link name="wrist">
    <visual><geometry><box size="0.025 0.025 0.030"/></geometry>
      <origin xyz="0 0 0.015"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.030 0.025 0.015"/></geometry>
      <origin xyz="0 0 0.0375"/><material name="darkblue"/></visual>
    <collision><geometry><box size="0.030 0.025 0.045"/></geometry><origin xyz="0 0 0.0225"/></collision>
    <inertial><mass value="0.05"/><origin xyz="0 0 0.0225"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/></inertial>
  </link>

  <joint name="wrist_joint" type="revolute">
    <parent link="forearm"/><child link="wrist"/>
    <origin xyz="0 0 0.095"/><axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="5" velocity="1.0"/>
  </joint>

  <!-- GRIPPER BASE -->
  <link name="gripper_base">
    <inertial><mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/></inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="wrist"/><child link="gripper_base"/>
    <origin xyz="0 0 0.045"/>
  </joint>

  <!-- GRIPPER LEFT -->
  <link name="gripper_left">
    <visual><geometry><box size="0.004 0.010 0.055"/></geometry>
      <origin xyz="0 0 0.0275"/><material name="green"/></visual>
    <visual><geometry><box size="0.004 0.010 0.012"/></geometry>
      <origin xyz="0.003 0 0.055" rpy="0 -0.3 0"/><material name="green"/></visual>
    <collision><geometry><box size="0.010 0.012 0.062"/></geometry><origin xyz="0.002 0 0.031"/></collision>
    <inertial><mass value="0.01"/><origin xyz="0 0 0.030"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000002"/></inertial>
  </link>

  <joint name="gripper_left_joint" type="revolute">
    <parent link="gripper_base"/><child link="gripper_left"/>
    <origin xyz="-0.008 0 0"/><axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.5" effort="2" velocity="1.0"/>
  </joint>

  <!-- GRIPPER RIGHT -->
  <link name="gripper_right">
    <visual><geometry><box size="0.004 0.010 0.055"/></geometry>
      <origin xyz="0 0 0.0275"/><material name="green"/></visual>
    <visual><geometry><box size="0.004 0.010 0.012"/></geometry>
      <origin xyz="-0.003 0 0.055" rpy="0 0.3 0"/><material name="green"/></visual>
    <collision><geometry><box size="0.010 0.012 0.062"/></geometry><origin xyz="-0.002 0 0.031"/></collision>
    <inertial><mass value="0.01"/><origin xyz="0 0 0.030"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000002"/></inertial>
  </link>

  <joint name="gripper_right_joint" type="revolute">
    <parent link="gripper_base"/><child link="gripper_right"/>
    <origin xyz="0.008 0 0"/><axis xyz="0 1 0"/>
    <limit lower="0" upper="0.5" effort="2" velocity="1.0"/>
    <mimic joint="gripper_left_joint" multiplier="1.0" offset="0"/>
  </joint>

</robot>
