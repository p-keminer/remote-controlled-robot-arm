    <origin xyz="0 0 0.018"/><axis xyz="0 0 -1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <!-- ======== SHOULDER BRACKET (fixed) ======== -->

  <link name="shoulder_bracket_l">
    <visual><geometry><box size="0.003 0.035 0.060"/></geometry>
      <origin xyz="-0.020 0 0.030"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.003 0.035 0.060"/></geometry>
      <origin xyz="0.020 0 0.030"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.043 0.003 0.036"/></geometry>
      <origin xyz="0 -0.0175 0.018"/><material name="darkblue"/></visual>
    <visual><geometry><box size="0.023 0.040 0.012"/></geometry>
