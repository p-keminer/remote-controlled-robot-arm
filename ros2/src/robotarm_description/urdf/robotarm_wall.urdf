<?xml version="1.0" ?>
<robot name="adeept_5dof_wall">

  <material name="darkblue"><color rgba="0.15 0.15 0.35 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="orange"><color rgba="0.95 0.6 0.1 1.0"/></material>
  <material name="green"><color rgba="0.1 0.75 0.5 1.0"/></material>
  <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
  <material name="wall"><color rgba="0.35 0.35 0.42 1.0"/></material>

  <!-- WAND -->
  <link name="wall">
    <visual><geometry><box size="0.18 0.005 0.18"/></geometry>
      <origin xyz="0 0 0.10"/><material name="wall"/></visual>
  </link>

  <!-- ======== BASE ======== -->

  <link name="base_link_l">
    <visual><geometry><box size="0.100 0.100 0.015"/></geometry>
      <origin xyz="0 0 0.0075"/><material name="darkblue"/></visual>
    <visual><geometry><cylinder radius="0.037" length="0.003"/></geometry>
      <origin xyz="0 0 0.0165"/><material name="grey"/></visual>
    <collision><geometry><box size="0.100 0.100 0.018"/></geometry><origin xyz="0 0 0.009"/></collision>
    <inertial><mass value="0.3"/><origin xyz="0 0 0.009"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="base_to_wall_l" type="fixed">
    <parent link="wall"/><child link="base_link_l"/>
    <origin xyz="0 0.0025 0.14" rpy="-1.5708 1.5708 0"/>
  </joint>

  <link name="base_link_r">
    <visual><geometry><box size="0.100 0.100 0.015"/></geometry>
      <origin xyz="0 0 0.0075"/><material name="darkblue"/></visual>
    <visual><geometry><cylinder radius="0.037" length="0.003"/></geometry>
      <origin xyz="0 0 0.0165"/><material name="grey"/></visual>
    <collision><geometry><box size="0.100 0.100 0.018"/></geometry><origin xyz="0 0 0.009"/></collision>
    <inertial><mass value="0.3"/><origin xyz="0 0 0.009"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <joint name="base_to_wall_r" type="fixed">
    <parent link="wall"/><child link="base_link_r"/>
    <origin xyz="0 -0.0025 0.14" rpy="1.5708 1.5708 0"/>
  </joint>

  <!-- ======== BASE JOINT (turntable) ======== -->

  <link name="turntable_l">
    <visual><geometry><cylinder radius="0.031" length="0.008"/></geometry>
      <origin xyz="0 0 0.004"/><material name="grey"/></visual>
    <collision><geometry><cylinder radius="0.032" length="0.008"/></geometry><origin xyz="0 0 0.004"/></collision>
    <inertial><mass value="0.05"/><origin xyz="0 0 0.004"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="base_joint_l" type="revolute">
    <parent link="base_link_l"/><child link="turntable_l"/>
    <origin xyz="0 0 0.018"/><axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1.0"/>
  </joint>

  <link name="turntable_r">
    <visual><geometry><cylinder radius="0.031" length="0.008"/></geometry>
      <origin xyz="0 0 0.004"/><material name="grey"/></visual>
    <collision><geometry><cylinder radius="0.032" length="0.008"/></geometry><origin xyz="0 0 0.004"/></collision>
    <inertial><mass value="0.05"/><origin xyz="0 0 0.004"/>
